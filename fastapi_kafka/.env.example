# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose loads .env automatically from this directory.

# Session cookie signing (use a long random string in production)
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# Google OAuth — from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must match an Authorized redirect URI in Google Cloud Console exactly
GOOGLE_REDIRECT_URI=http://localhost:5004/auth/google/callback

# --- Render production (set on each service in Render dashboard) ---
# web_client:
#   LOGIN_SERVER_URL=https://YOUR-login-server.onrender.com
#   GOOGLE_REDIRECT_URI=https://YOUR-web-client.onrender.com/auth/google/callback
#   WEBSOCKET_CLIENT_URL=wss://YOUR-websocket-server.onrender.com/ws
# websocket_server:
#   CHANNEL_MANAGER_URL=https://YOUR-channel-manager.onrender.com
#   PUBLIC_KEY_PATH=/etc/secrets/public_key.pem
# login_server + channel_manager (same DATABASE_URL):
#   DATABASE_URL=<Render Postgres internal URL>
#   PRIVATE_KEY_PATH=/etc/secrets/private_key.pem
#   PUBLIC_KEY_PATH=/etc/secrets/public_key.pem
# channel_manager:
#   MONGODB_URL=<MongoDB Atlas connection string>

# Kafka — leave SASL vars empty for local Docker (compose.kafka.yaml)
KAFKA_BROKER=kafka-1:9092
# Confluent Cloud (Render): bootstrap host:9092 + API key/secret
# KAFKA_BROKER=pkc-xxxxx.us-east-2.aws.confluent.cloud:9092
# KAFKA_API_KEY=your-confluent-api-key
# KAFKA_API_SECRET=your-confluent-api-secret
